{
  "name": "workspace",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "start:backend": "npm --workspace apps/backend run start",
    "start:frontend": "npm --workspace apps/frontend run start",
    "start:all": "npm-run-all --parallel start:backend start:frontend",
    "test:backend": "npm --workspace apps/backend run test",
    "test:frontend": "npm --workspace apps/frontend run test"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.0"
  }
}
